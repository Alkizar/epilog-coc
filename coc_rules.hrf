% inductive List (A : Type) : Type where
%   | nil : List A
%   | cons : A -> List A -> List B


%% TODO: if struct takes parameters then the inferred type should be an application of var(Struct_Name) to the arguments
get_struct_from_app(var(Struct), Struct, 0)
get_struct_from_app(app(Fun, Arg), Struct, N) :- get_struct_from_app(Fun, Struct, M) & evaluate(plus(M, 1), N)

strip_pi_from_proj(Proj_Dom, 0, Proj_Dom)
strip_pi_from_proj(pi(X, Ty, Body), Num_Params, Ty) :- evaluate(minus(Num_Params, 1), N) & strip_pi_from_proj(Body, N, Ty)

infer(proj(Term, Field), Ctx, Cod_Ty) :- infer(Term, Ctx, Ty) & get_struct_from_app(Ty, Struct_Name, Num_Params) & make_proj_name(Struct_Name, Field, Proj_Name) & ctx.lookup_axiom(Ctx, Proj_Name, pi(X, Dom_Ty, Cod_Ty)) & def_eq(Dom_Ty, var(Struct_Name), Ctx)