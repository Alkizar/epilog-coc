%%%%%%%%%%%%%%
%%% Misc. Utilities
%%%%%%%%%%%%%%

empty(nil)
refl(X, X)

eq_len(Xs, Ys) :- evaluate(length(Xs), N) & evaluate(length(Ys), N)

append_elt(nil, Y, [Y])
append_elt(cons(X, Xs), Y, cons(X, Zs)) :- append_elt(Xs, Y, Zs)

rev(nil, nil)
rev(cons(X, Xs), Ws) :-  rev(Xs, Zs) & append_elt(Zs, X, Ws)


%%%%%%%%%%%%%%
%%% Structure
%%%%%%%%%%%%%%

is_term(var(X))
is_term(app(Fun, Arg)) :- is_term(Fun) & is_term(Arg)
is_term(abs(X, Ty, Body)) :- is_term(Ty) & is_term(Body)
is_term(pi(X, Ty, Body)) :- is_term(Ty) & is_term(Body)
is_term(usort(Uni)) :- is_universe(Uni)
is_term(match(Target, Arms)) :- is_term(Target) & all_arms(Arms)
is_term(constructor(Name, Args)) :- all_terms(Args)
is_term(proj(Term, Field)) :- is_term(Term)

is_var(var(X))
is_app(app(Fun, Arg))
is_abs(abs(X, Ty, Body))
is_pi(pi(X, Ty, Body))
is_usort(usort(Uni))
is_match(match(Target, Arms))
is_constructor(constructor(Name, Args))
is_proj(proj(Term, Field))

is_universe(uconst(N))
is_universe(uvar(X))
is_universe(uadd(U, N)) :- is_universe(U)
is_universe(umax(U, V)) :- is_universe(U) & is_universe(V)

is_uconst(uconst(N)) :- number(N)
is_uvar(uvar(X))
is_uadd(uadd(U, N)) :- is_universe(U)
is_umax(umax(U, V)) :- is_universe(U) & is_universe(V)

is_parameter(parameter(Name, Ty)) :- is_term(Ty)

is_constr_decl(constr_decl(Name, Ty)) :- is_term(Ty)

is_field(field(Name, Ty)) :- is_term(Ty)

is_arm(match.arm(Pattern, Body)) :- is_pattern(Pattern) & is_term(Body)

is_pattern(pattern.var(X))
is_pattern(pattern.constructor(X, Patterns)) :- all_patterns(Patterns)
is_pattern(pattern.wildcard)

is_uni_param(universe.parameter(Name))

all_terms(nil)
all_terms(cons(Term, Rest)) :- is_term(Term) & all_terms(Rest)

all_uni(nil)
all_uni(cons(Uni, Rest)) :- is_universe(Uni) & all_uni(Rest)

all_params(nil)
all_params(cons(Param, Rest)) :- is_parameter(Param) & all_params(Rest)

all_constr_decls(nil)
all_constr_decls(cons(Constr, Rest)) :- is_constr_decl(Constr) & all_constr_decls(Rest)

all_fields(nil)
all_fields(cons(Field, Rest)) :- is_field(Field) & all_fields(Rest)

all_arms(nil)
all_arms(cons(Arm, Rest)) :- is_arm(Arm) & all_arms(Rest)

all_patterns(nil)
all_patterns(cons(Pattern, Rest)) :- is_pattern(Pattern) & all_patterns(Rest)

all_uni_param(nil)
all_uni_param(const(Uni_Param, Rest)) :- is_uni_param(Uni_Param) & all_uni_param(Rest)

is_axiom(axiom(Name, Uni_Params, Ty)) :- all_uni_param(Uni_Params) & is_term(Ty)

is_def(def(Name, Uni_Params, Params, Ty, Body)) :- all_uni_param(Uni_Params) & all_params(Params) & is_term(Ty) & is_term(Body)

is_induct(inductive(Name, Uni_Params, Params, Ty, Constrs)) :- all_uni_param(Uni_Params) & all_params(Params) & is_term(Ty) & all_constr_decls(Constrs)

is_struct(struct(Name, Uni_Params, Params, Ty, Fields)) :- all_uni_param(Uni_Params) & all_params(Params) & is_term(Ty) & all_fields(Fields)


%%%%%%%%%%%%%%
%%% Universes
%%%%%%%%%%%%%%

universe.normalize(uadd(uconst(N), M), uconst(R)) :- evaluate(plus(N, M), R)
universe.normalize(uadd(U, N), uadd(U, N)) :- is_universe(U) & ~is_uconst(U)
universe.normalize(umax(U, V), uconst(R)) :- universe.normalize(U, uconst(N)) & universe.normalize(V, uconst(M)) & evaluate(max(N, M), R)
universe.normalize(umax(U, V), umax(U, V)) :- universe.normalize(U, Nf_U) & universe.normalize(V, Nf_V) & ~is_uconst(Nf_U)
universe.normalize(umax(U, V), umax(U, V)) :- universe.normalize(U, Nf_U) & universe.normalize(V, Nf_V) & ~is_uconst(Nf_V)
universe.normalize(U, U) :- is_universe(U) & ~is_uadd(U) & ~is_umax(U)

universe.unify(uconst(N), uconst(N))
universe.unify(uvar(X), uvar(X))
universe.unify(uadd(U, N), uconst(M)) :- evaluate(minus(M, N), R) & leq(0, R) & universe.unify(U, uconst(R))
universe.unify(uconst(M), uadd(U, N)) :- evaluate(minus(M, N), R) & leq(0, R) & universe.unify(U, uconst(R))
universe.unify(uadd(U, N), uadd(V, N)) :- universe.unify(U, V)
universe.unify(umax(U1, V1), umax(U2, V2)) :- universe.unify(U1, U2) & universe.unify(V1, V2)

%% Terms should be in de Bruijn form before solving for universes.
universe.solve(var(X), var(X))
universe.solve(app(Fun1, Arg1), app(Fun2, Arg2)) :- universe.solve(Fun1, Fun2) & universe.solve(Arg1, Arg2)
universe.solve(abs(X, Ty1, Body1), abs(X, Ty2, Body2)) :- universe.solve(Ty1, Ty2) & universe.solve(Body1, Body2)
universe.solve(pi(X, Ty1, Body1), pi(X, Ty2, Body2)) :- universe.solve(Ty1, Ty2) & universe.solve(Body1, Body2)
universe.solve(usort(U), usort(V)) :- universe.unify(U, V)
universe.solve(usort(U), usort(V)) :- universe.unify(V, U)
universe.solve(match(Target1, Arms1), match(Target2, Arms2)) :- universe.solve(Target1, Target2) & universe.solve_arms(Arms1, Arms2)
universe.solve(constructor(Name1, Args1), constructor(Name2, Args2)) :- universe.solve_args(Args1, Args2)
universe.solve(proj(Term1, Field1), proj(Term2, Field2)) :- universe.solve(Term1, Term2)

universe.solve_arms(nil, nil)
universe.solve_arms(cons(match.arm(Pattern1, Body1), Rest1), cons(match.arm(Pattern2, Body2), Rest2)) :- universe.solve(Body1, Body2) & universe.solve_arms(Rest1, Rest2)

universe.solve_args(nil, nil)
universe.solve_args(cons(Arg1, Rest1), cons(Arg2, Rest2)) :- universe.solve(Arg1, Arg2) & universe.solve_args(Rest1, Rest2)

%%%%%%%%%%%%%%
%%% Contexts
%%%%%%%%%%%%%%

%% Map interface

map.insert(nil, New_Key, New_Val, [map.entry(New_Key, New_Val)])
map.insert(cons(map.entry(New_Key, Val), Map), New_Key, New_Val, cons(map.entry(New_Key, New_Val), Map))
map.insert(cons(map.entry(Key, Val), Map), New_Key, New_Val, cons(map.entry(Key, Val), New_Map)) :- distinct(Key, New_Key) & map.insert(Map, New_Key, New_Val, New_Map)

map.lookup(cons(map.entry(Key, Val), Map), Key, Val)
map.lookup(cons(map.entry(Other_Key, Other_Val), Map), Key, Val) :- map.lookup(Map, Key, Val)

map.contains(Map, Key) :- map.lookup(Map, Key, Val)

%% Context interface

%% TODO: fix the structure names in the context (eg. ctx.def)
ctx.lookup_var(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Var, Term) :- map.lookup(Var_Map, Var, Term)
ctx.extend_var(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Var, Term, ctx(New_Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx)) :- map.insert(Var_Map, Var, Term, New_Var_Map)
ctx.extend_vars(Ctx, nil, Ctx)
ctx.extend_vars(Ctx, cons(parameter(Name, Ty), Rest), New_Ctx) :- ctx.extend_var(Ctx, Name, Ty, Inter_Ctx) & ctx.extend_vars(Inter_Ctx, Rest, New_Ctx)
ctx.contains_var(Ctx, Var) :- ctx.lookup_var(Ctx, Var, Term)

ctx.lookup_constr(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Name, Term) :- map.lookup(Constr_Map, Name, Term)
ctx.extend_constr(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Name, Term, ctx(Var_Map, Uni_Map, New_Constr_Map, Axiom_Map, Def_Map, Uni_Ctx)) :- map.insert(Constr_Map, Name, Term, New_Constr_Map)
ctx.contains_constr(Ctx, Name) :- ctx.lookup_constr(Ctx, Name, Term)

ctx.lookup_axiom(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Axiom, Term) :- map.lookup(Axiom_Map, Axiom, Term)
ctx.extend_axiom(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Axiom, Term, ctx(Var_Map, Uni_Map, Constr_Map, New_Axiom_Map, Def_Map, Uni_Ctx)) :- map.insert(Axiom_Map, Axiom, Term, New_Axiom_Map)
ctx.contains_axiom(Ctx, Axiom) :- ctx.lookup_axiom(Ctx, Axiom, Term)

ctx.lookup_def(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Name, Def) :- map.lookup(Def_Map, Name, Def)
ctx.extend_def(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Name, Uni_Params, Ty, ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, New_Def_Map, Uni_Ctx)) :- map.insert(Def_Map, Name, ctx.def(Uni_Params, Ty), New_Def_Map)
ctx.contains_def(Ctx, Name) :- ctx.lookup_def(Ctx, Name, Def)

ctx.universe_ctx(ctx(Var_Map, Uni_Map, Constr_Map, Axiom_Map, Def_Map, Uni_Ctx), Uni_Ctx)


ctx.nil(ctx(nil, nil, nil, nil, nil, nil))

%%%%%%%%%%%%%%
%%% Substitution
%%%%%%%%%%%%%%

%% Replaces all occurences of the universe variable "u" with Substitution("u"), for each key "u" in the Substitution map
% uni_subst_all(Term, Substitution, New_Term)
uni_subst_all(usort(U), Substitution, usort(New_U)) :- uni_subst(U, Substitution, New_U)

uni_subst_all(var(X), Substitution, var(X))
uni_subst_all(app(Fun, Arg), Substitution, app(Sub_Fun, Sub_Arg)) :- uni_subst_all(Fun, Substitution, Sub_Fun) & uni_subst_all(Arg, Substitution, Sub_Arg)
uni_subst_all(abs(X, Ty, Body), Substitution, abs(X, Sub_Ty, Sub_Body)) :- uni_subst_all(Ty, Substitution, Sub_Ty) & uni_subst_all(Body, Substitution, Sub_Body)
uni_subst_all(pi(X, Ty, Body), Substitution, pi(X, Sub_Ty, Sub_Body)) :- uni_subst_all(Ty, Substitution, Sub_Ty) & uni_subst_all(Body, Substitution, Sub_Body)
uni_subst_all(proj(Term, Field), Substitution, proj(Sub_Term, Field)) :- uni_subst_all(Term, Substitution, Sub_Field)
uni_subst_all(Term, Substitution, Term) :- ~is_usort(Term) & ~is_var(Term) & ~is_app(Term) & ~is_abs(Term) & ~is_pi(Term) & ~is_proj(Term)

uni_subst(uvar(U), Substitution, New_U) :- map.lookup(Substitution, U, New_U)
uni_subst(uvar(U), Substitution, uvar(U)) :- ~map.contains(Substitution, U)
uni_subst(uconst(N), Substitution, uconst(N))
uni_subst(uadd(U, N), Substitution, uadd(New_U, N)) :- uni_subst(U, Substitution, New_U)
uni_subst(umax(U, V), Substitution, umax(New_U, New_V)) :- uni_subst(U, Substitution, New_U) & uni_subst(V, Substitution, New_V)

is_bound(cons(X, Xs), X)
is_bound(cons(Y, Ys), X) :- distinct(Y, X) & is_bound(Ys, X)

fresh_var(X, nil, Y) :- evaluate(stringappend(X, "_"), Y)
fresh_var(X, cons(Z, Zs), Y) :- fresh_var(X, Zs, W) & evaluate(stringappend(W, Z), Y)

occurs_free(Y, var(Y))
occurs_free(X, app(Fun, Arg)) :- occurs_free(X, Fun)
occurs_free(X, app(Fun, Arg)) :- occurs_free(X, Arg)
occurs_free(X, abs(Y, Ty, Body)) :- occurs_free(X, Ty)
occurs_free(X, abs(Y, Ty, Body)) :- distinct(X, Y) & occurs_free(X, Body)
occurs_free(X, pi(Y, Ty, Body)) :- occurs_free(X, Ty)
occurs_free(X, pi(Y, Ty, Body)) :- distinct(X, Y) & occurs_free(X, Body)
occurs_free(X, match(Target, Arms)) :- occurs_free(X, Target)
occurs_free(X, match(Target, Arms)) :- occurs_free_arms(X, Arms)
occurs_free(X, constructor(Name, Args)) :- occurs_free_args(X, Args)
occurs_free(X, proj(Term, Target)) :- occurs_free(X, Term)

occurs_free_arms(X, cons(match.arm(Pattern, Body), Rest)) :- occurs_free(X, Body)
occurs_free_arms(X, cons(match.arm(Pattern, Body), Rest)) :- occurs_free_arms(X, Rest)

occurs_free_args(X, cons(Arg, Rest)) :- occurs_free(X, Arg)
occurs_free_args(X, cons(Arg, Rest)) :- occurs_free_args(X, Rest)

rename_var(Prev, New, var(Prev), var(New))
rename_var(Prev, New, var(X), var(X)) :- distinct(Prev, X)
rename_var(Prev, New, app(Fun, Arg), app(R_Fun, R_Arg)) :- rename_var(Prev, New, Fun, R_Fun) & rename_var(Prev, New, Arg, R_Arg)
rename_var(Prev, New, abs(Prev, Ty, Body), abs(New, R_Ty, Body)) :- rename_var(Prev, New, Ty, R_Ty)
rename_var(Prev, New, abs(X, Ty, Body), abs(X, R_Ty, R_Body)) :- distinct(Prev, X) & rename_var(Prev, New, Ty, R_Ty) & rename_var(Prev, New, Body, R_Body)
rename_var(Prev, New, pi(Prev, Ty, Body), pi(Prev, R_Ty, Body)) :- rename_var(Prev, New, Fun, R_Fun)
rename_var(Prev, New, pi(X, Ty, Body), pi(X, R_Ty, R_Body)) :- distinct(Prev, X) & rename_var(Prev, New, Ty, R_Ty) & rename_var(Prev, New, Body, R_Body)
rename_var(Prev, New, match(Target, Arms), match(R_Target, R_Arms)) :- rename_var(Prev, New, Target, R_Target) & rename_var_arms(Prev, New, Arms, R_Arms)
rename_var(Prev, New, proj(Term, Field), match(R_Term, Field)) :- rename_var(Prev, New, Term, R_Term)
rename_var(Prev, New, Term, Term) :- ~is_var(Term) & ~is_app(Term) & ~is_abs(Term) & ~is_pi(Term) & ~is_match(Term) & ~is_proj(Term)

rename_var_arms(Prev, New, nil, nil)
rename_var_arms(Prev, New, cons(match.arm(Pattern, Body), Rest), cons(match.arm(Pattern, Body), R_Rest)) :- pattern_binds_var(Pattern, Prev) & rename_var_arms(Prev, New, Rest, R_Rest)
rename_var_arms(Prev, New, cons(match.arm(Pattern, Body), Rest), cons(match.arm(Pattern, R_Body), R_Rest)) :- ~pattern_binds_var(Pattern, Prev) & rename_var(Prev, New, Body, R_Body) & rename_var_arms(Prev, New, Rest, R_Rest)

substitute_with_context(X, Src, var(X), Bound, Src) :- ~is_bound(Bound, X)
substitute_with_context(X, Src, var(X), Bound, var(X)) :- is_bound(Bound, X)
substitute_with_context(X, Src, var(Y), Bound, var(Y)) :- distinct(X, Y)

substitute_with_context(X, Src, app(Fun, Arg), Bound, app(Sub_Fun, Sub_Arg)) :- substitute_with_context(X, Src, Fun, Bound, Sub_Fun) & substitute_with_context(X, Src, Arg, Bound, Sub_Arg)

substitute_with_context(X, Src, abs(X, Ty, Body), Bound, abs(X, Sub_Ty, Body)) :- substitute_with_context(X, Src, Ty, Bound, Sub_Ty)
substitute_with_context(X, Src, abs(Y, Ty, Body), Bound, abs(Fresh, Sub_Ty, Sub_Body)) :- distinct(X, Y) & occurs_free(Y, Src) & fresh_var(Y, Bound, Fresh) & rename_var(Y, Fresh, Body, New_Body) & substitute_with_context(X, Src, Ty, cons(Fresh, Bound), Sub_Ty) & substitute_with_context(X, Src, New_Body, cons(Fresh, Bound), Sub_Body)
substitute_with_context(X, Src, abs(Y, Ty, Body), Bound, abs(Y, Sub_Ty, Sub_Body)) :- distinct(X, Y) & ~occurs_free(Y, Src) & substitute_with_context(X, Src, Ty, cons(Y, Bound), Sub_Ty) & substitute_with_context(X, Src, Body, cons(Y, Bound), Sub_Body)

substitute_with_context(X, Src, pi(X, Ty, Body), Bound, pi(X, Sub_Ty, Body)) :- substitute_with_context(X, Src, Ty, Bound, Sub_Ty)
substitute_with_context(X, Src, pi(Y, Ty, Body), Bound, pi(Fresh, Sub_Ty, Sub_Body)) :- distinct(X, Y) & occurs_free(Y, Src) & fresh_var(Y, Bound, Fresh) & rename_var(Y, Fresh, Body, New_Body) & substitute_with_context(X, Src, Ty, cons(Fresh, Bound), Sub_Ty) & substitute_with_context(X, Src, New_Body, cons(Fresh, Bound), Sub_Body)
substitute_with_context(X, Src, pi(Y, Ty, Body), Bound, pi(Y, Sub_Ty, Sub_Body)) :- distinct(X, Y) & ~occurs_free(Y, Src) & substitute_with_context(X, Src, Ty, cons(Y, Bound), Sub_Ty) & substitute_with_context(X, Src, Body, cons(Y, Bound), Sub_Body)

substitute_with_context(X, Src, match(Target, Arms), Bound, match(Sub_Target, Sub_Arms)) :- substitute_with_context(X, Src, Target, Bound, Sub_Target) & substitute_arms_with_context(X, Src, Arms, Bound, Sub_Arms)

substitute_with_context(X, Src, proj(Term, Field), Bound, proj(Sub_Term, Field)) :- substitute_with_context(X, Src, Term, Bound, Sub_Term)

substitute_with_context(X, Src, Tgt, Bound, Tgt) :- ~is_var(Tgt) & ~is_app(Tgt) & ~is_abs(Tgt) & ~is_pi(Tgt) & ~is_match(Tgt) & ~is_proj(Tgt)

substitute_arms_with_context(X, Src, nil, Bound, nil)
substitute_arms_with_context(X, Src, cons(match.arm(Pattern, Body), Rest), Bound, cons(match.arm(Pattern, Body), Sub_Rest)) :- pattern_binds_var(Pattern, X) & substitute_arms_with_context(X, Src, Rest, Bound, Sub_Rest)
substitute_arms_with_context(X, Src, cons(match.arm(Pattern, Body), Rest), Bound, cons(match.arm(Pattern, Sub_Body), Sub_Rest)) :- ~pattern_binds_var(Pattern, X) & substitute_with_context(X, Src, Body, Bound, Sub_Body) & substitute_arms_with_context(X, Src, Rest, Bound, Sub_Rest)

pattern_binds_var(pattern.var(X), X)
pattern_binds_var(pattern.constructor(Name, Patterns), X) :- pattern_binds_var_any(Patterns, X)

pattern_binds_var_any(cons(Pattern, Rest), X) :- pattern_binds_var(Pattern, X)
pattern_binds_var_any(cons(Pattern, Rest), X) :- pattern_binds_var_any(Rest, X)

substitute(X, Src, Tgt, Result) :- substitute_with_context(X, Src, Tgt, nil, Result)


%%%%%%%%%%%%%%
%%% Equivalence
%%%%%%%%%%%%%%

%% Convert variable names to de Bruijn indices

alpha_normalize_rec(var(X), Db_Ctx, N, var(M)) :- map.lookup(Db_Ctx, X, M)
alpha_normalize_rec(var(X), Db_Ctx, N, var(X)) :- ~map.contains(Db_Ctx, X)
alpha_normalize_rec(app(Fun, Arg), Db_Ctx, N, app(Db_Fun, Db_Arg)) :- alpha_normalize_rec(Fun, Db_Ctx, N, Db_Fun) & alpha_normalize_rec(Arg, Db_Ctx, N, Db_Arg)
alpha_normalize_rec(abs(X, Ty, Body), Db_Ctx, N, abs(M, Db_Ty, Db_Body)) :- evaluate(plus(N, 1), M) & map.insert(Db_Ctx, X, M, Ext_Db_Ctx) & alpha_normalize_rec(Ty, Ext_Db_Ctx, M, Db_Ty) & alpha_normalize_rec(Body, Ext_Db_Ctx, M, Db_Body)
alpha_normalize_rec(pi(X, Ty, Body), Db_Ctx, N, pi(M, Db_Ty, Db_Body)) :- evaluate(plus(N, 1), M) & map.insert(Db_Ctx, X, M, Ext_Db_Ctx) & alpha_normalize_rec(Ty, Ext_Db_Ctx, M, Db_Ty) & alpha_normalize_rec(Body, Ext_Db_Ctx, M, Db_Body)
alpha_normalize_rec(usort(U), Db_Ctx, N, usort(U))
alpha_normalize_rec(proj(Term, Field), Db_Ctx, N, proj(Db_Term, Field)) :- alpha_normalize_rec(Term, Db_Ctx, N, Db_Term)
alpha_normalize_rec(match(Target, Arms), Db_Ctx, N, match(Db_Target, Db_Arms)) :- alpha_normalize_rec(Target, Db_Ctx, N, Db_Target) & alpha_normalize_arms(Arms, Db_Ctx, N, Db_Arms)
alpha_normalize_rec(constructor(Name, Args), Db_Ctx, N, constructor(Name, Db_Args)) :- alpha_normalize_args(Args, Db_Ctx, N, Db_Args)
alpha_normalize_rec(Term, Db_Ctx, N, Term) :- ~is_var(Term) & ~is_app(Term) & ~is_abs(Term) & ~is_pi(Term) & ~is_usort(Term) & ~is_match(Term) & ~is_constructor(Term) & ~is_proj(Term)

%% TODO: check that this behaves correctly for universes!
%% TODO: finish this
% alpha_normalize_uni(uconst(M), Db_Ctx, N, uconst(M))
% alpha_normalize_uni(uvar(X), Db_Ctx, N, uvar(M)) :- map.lookup(Db_Ctx, X, M)
% alpha_normalize_uni(uadd(U, M), Db_Ctx, N, uadd(Db_U, M)) :- alpha_normalize_uni(U, Db_Ctx, N, Db_U)
% alpha_normalize_uni(umax(U, V), Db_Ctx, N, umax)

alpha_normalize(Term, Db_Term) :- alpha_normalize_rec(Term, nil, 0, Db_Term)

alpha_equiv(Term1, Term2) :- alpha_normalize(Term1, Db) & alpha_normalize(Term2, Db)

%% app(Fun, Arg)
normalize(app(Fun, Arg), Ctx, app(Nf_Fun, Nf_Arg)) :- normalize(Fun, Ctx, Nf_Fun) & normalize(Arg, Ctx, Nf_Arg) & ~is_abs(Nf_Fun)
normalize(app(Fun, Arg), Ctx, Nf) :- normalize(Fun, Ctx, abs(Nf_X, Nf_Ty, Nf_Body)) & normalize(Arg, Ctx, Nf_Arg) & substitute(Nf_X, Nf_Arg, Nf_Body, Nf)

%% abs(X, Ty, Body) 
normalize(abs(X, Ty, Body), Ctx, Nf_Fun) :- normalize(Ty, Ctx, Nf_Ty) & ctx.extend_var(Ctx, X, Nf_Ty, Ext_Ctx) & normalize(Body, Ext_Ctx, app(Nf_Fun, var(Nf_Var))) & ~occurs_free(Nf_Var, Nf_Fun)
normalize(abs(X, Ty, Body), Ctx, abs(X, Nf_Ty, Nf_Body)) :- normalize(Ty, Ctx, Nf_Ty) & ctx.extend_var(Ctx, X, Nf_Ty, Ext_Ctx) & normalize(Body, Ext_Ctx, Nf_Body) & ~is_app(Nf_Body)
normalize(abs(X, Ty, Body), Ctx, abs(X, Nf_Ty, app(Nf_Fun, var(Nf_Var)))) :- normalize(Ty, Ctx, Nf_Ty) & ctx.extend(Ctx, X, Nf_Ty, Ext_Ctx) & normalize(Body, Ext_Ctx, app(Nf_Fun, var(Nf_Var))) & occurs_free(Nf_Var, Nf_Fun)

%% pi(X, Ty, Body)
normalize(pi(X, Ty, Body), Ctx, pi(X, Nf_Ty, Nf_Body)) :- normalize(Ty, Ctx, Nf_Ty) & ctx.extend_var(Ctx, X, Nf_Ty, Ext_Ctx) & normalize(Body, Ext_Ctx, Nf_Body)

%% var(X)
normalize(var(X), Ctx, Def) :- ctx.lookup_axiom(Ctx, X, Def)
normalize(var(X), Ctx, var(X)) :- ~ctx.contains_axiom(Ctx, X)

%% Other terms
normalize(Term, Ctx, Term) :- ~is_app(Term) & ~is_abs(Term) & ~is_pi(Term) & ~is_var(Term)


%% Checks whether the inputs are definitionally equal in the provided context
%% TODO: make sure normalize also handles alpha conversion
def_eq(Term1, Term2, Ctx) :- normalize(Term1, Ctx, Nf1) & normalize(Term2, Ctx, Nf2) & unify(Nf1, Nf2) & normalize(Nf1, Ctx, Nff1) & normalize(Nf1, Ctx, Nff2) & alpha_equiv(Nff1, Nff2)
% TODO: unify, alpha_equiv


%% TODO: need to do this in BFS order to ensure termination when meta variables are involved!

max_depth(4)

iter_depth(Depth, Succ_Depth) :- evaluate(plus(Depth, 1), Succ_Depth) & max_depth(Max) & leq(Succ_Depth, Max)

alpha_bounded_normalize_rec(var(X), Db_Ctx, N, var(M), Depth) :- map.lookup(Db_Ctx, X, M)
alpha_bounded_normalize_rec(var(X), Db_Ctx, N, var(X), Depth) :- ~map.contains(Db_Ctx, X) 
alpha_bounded_normalize_rec(app(Fun, Arg), Db_Ctx, N, app(Db_Fun, Db_Arg), Depth) :- iter_depth(Depth, Succ_Depth) & alpha_bounded_normalize_rec(Fun, Db_Ctx, N, Db_Fun, Succ_Depth) & alpha_bounded_normalize_rec(Arg, Db_Ctx, N, Db_Arg, Succ_Depth)
alpha_bounded_normalize_rec(abs(X, Ty, Body), Db_Ctx, N, abs(M, Db_Ty, Db_Body), Depth) :- iter_depth(Depth, Succ_Depth) & evaluate(plus(N, 1), M) & map.insert(Db_Ctx, X, M, Ext_Db_Ctx) & alpha_bounded_normalize_rec(Ty, Ext_Db_Ctx, M, Db_Ty, Succ_Depth) & alpha_bounded_normalize_rec(Body, Ext_Db_Ctx, M, Db_Body, Succ_Depth)
alpha_bounded_normalize_rec(pi(X, Ty, Body), Db_Ctx, N, pi(M, Db_Ty, Db_Body), Depth) :- iter_depth(Depth, Succ_Depth) & evaluate(plus(N, 1), M) & map.insert(Db_Ctx, X, M, Ext_Db_Ctx) & alpha_bounded_normalize_rec(Ty, Ext_Db_Ctx, M, Db_Ty, Succ_Depth) & alpha_bounded_normalize_rec(Body, Ext_Db_Ctx, M, Db_Body, Succ_Depth)
alpha_bounded_normalize_rec(usort(U), Db_Ctx, N, usort(U), Depth)
alpha_bounded_normalize_rec(proj(Term, Field), Db_Ctx, N, proj(Db_Term, Field), Depth) :- iter_depth(Depth, Succ_Depth) & alpha_bounded_normalize_rec(Term, Db_Ctx, N, Db_Term, Succ_Depth)
alpha_bounded_normalize_rec(match(Target, Arms), Db_Ctx, N, match(Db_Target, Db_Arms), Depth) :- iter_depth(Depth, Succ_Depth) & alpha_bounded_normalize_rec(Target, Db_Ctx, N, Db_Target, Succ_Depth) & alpha_bounded_normalize_arms(Arms, Db_Ctx, N, Db_Arms, Succ_Depth)
alpha_bounded_normalize_rec(constructor(Name, Args), Db_Ctx, N, constructor(Name, Db_Args), Depth) :- iter_depth(Depth, Succ_Depth) & alpha_bounded_normalize_args(Args, Db_Ctx, N, Db_Args, Succ_Depth)
alpha_bounded_normalize_rec(Term, Db_Ctx, N, Term, Depth) :- ~is_var(Term) & ~is_app(Term) & ~is_abs(Term) & ~is_pi(Term) & ~is_usort(Term) & ~is_match(Term) & ~is_constructor(Term) & ~is_proj(Term)

alpha_bounded_normalize_arms(nil, Db_Ctx, N, nil, Depth)
alpha_bounded_normalize_arms(cons(match.arm(Pattern, Body), Rest), Db_Ctx, N, cons(match.arm(Db_Pattern, Db_Body), Db_Rest), Depth) :- alpha_bounded_normalize_rec(Body, Db_Ctx, N, Db_Body, Depth) & alpha_bounded_normalize_arms(Rest, Db_Ctx, N, Db_Rest, Depth)

alpha_bounded_normalize_args(nil, Db_Ctx, N, nil, Depth)
alpha_bounded_normalize_args(cons(Arg, Rest), Db_Ctx, N, cons(Db_Arg, Db_Rest), Depth) :- alpha_bounded_normalize_rec(Arg, Db_Ctx, N, Db_Arg, Depth) & alpha_bounded_normalize_args(Rest, Db_Ctx, N, Db_Rest, Depth)

alpha_bounded_normalize(Term, Db_Term) :- alpha_bounded_normalize_rec(Term, nil, 0, Db_Term, 0)

% TODO this appears to work! test -> alpha_normalize_rec, alpha_test -> alpha_normalize


%%%%%%%%%%%%%%
%%% Unification
%%%%%%%%%%%%%%


%% TODO: I think alpha conversion to debruijn needs to be guaranteed before attempts to unify; maybe handle this during parsing? jk just do this in the calls to unify (eg alpha -> unify)

% unify(Term1, Term2) :- is_term(Term1) & is_term(Term2) & alpha_equiv(Term1, Term2) %% TODO: is this correct?

% unify(Term1, Term2) :- is_pi(Term1) & is_pi(Term2) & alpha_equiv(Term1, Term2)
% unify(Term1, Term2) :- is_var(Term1) & is_var(Term2) & alpha_equiv(Term1, Term2)
% unify(Term1, Term2) :- is_usort(Term1) & is_usort(Term2) & alpha_equiv(Term1, Term2)
% unify(Term1, Term2) :- is_term(Term1) & is_term(Term2) & alpha_equiv(Term1, Term2)

unify(Term1, Term2) :- alpha_bounded_normalize(Term1, Db_Term1) & alpha_bounded_normalize(Term2, Db_Term2) & universe.solve(Db_Term1, Db_Term2)
unify(Term1, Term2) :- alpha_bounded_normalize(Term2, Db_Term2) & alpha_bounded_normalize(Term1, Db_Term1) & universe.solve(Db_Term2, Db_Term1)

